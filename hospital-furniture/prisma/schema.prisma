generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  USER
}

enum FurnitureStatus {
  NOVO
  USADO
  MANUTENCAO
  CONDENADO
}

enum RequestStatus {
  PENDENTE      // Aguardando análise da gerência
  EM_SEPARACAO  // Aprovado, hotelaria está preparando o item
  EM_TRANSITO   // Saiu do almoxarifado rumo ao setor
  ENTREGUE      // Chegou no destino final
  RECUSADO      // Solicitação negada
}

enum MovementType {
  ENTRADA
  SAIDA
  TRANSFERENCIA
  MANUTENCAO
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  requests  Request[]

  @@map("users")
}

model Furniture {
  id        String          @id @default(cuid())
  name      String
  type      String
  quantity  Int             @default(0)
  status    FurnitureStatus @default(NOVO)
  location  String
  patrimony String?         
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  requests  Request[]
  movements Movement[]

  @@map("furniture")
}

model Request {
  id          String        @id @default(cuid())
  userId      String
  type        String        // O tipo de item solicitado (ex: "Maca")
  furnitureId String?       // Fica nulo até o William vincular um patrimônio na entrega
  quantity    Int           @default(1)
  reason      String
  sector      String
  status      RequestStatus @default(PENDENTE)
  notes       String?       
  reviewedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user      User       @relation(fields: [userId], references: [id])
  furniture Furniture? @relation(fields: [furnitureId], references: [id])

  @@map("requests")
}

model Movement {
  id          String       @id @default(cuid())
  furnitureId String
  type        MovementType
  quantity    Int
  description String
  date        DateTime     @default(now())
  createdAt   DateTime     @default(now())

  furniture Furniture @relation(fields: [furnitureId], references: [id])

  @@map("movements")
}