generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  USER
}

enum FurnitureStatus {
  NOVO
  USADO
  MANUTENCAO
  CONDENADO
}

enum RequestStatus {
  PENDENTE      // Aguardando análise da gerência
  EM_COMPRA     // NOVO STATUS: Aprovado, mas aguardando suprimentos/compras
  EM_SEPARACAO  // Aprovado, hotelaria está preparando o item
  EM_TRANSITO   // Saiu do almoxarifado rumo ao setor
  ENTREGUE      // Chegou no destino final
  RECUSADO      // Solicitação negada
}

enum MovementType {
  ENTRADA
  SAIDA
  TRANSFERENCIA
  MANUTENCAO
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  requests  Request[]

  @@map("users")
}

model Furniture {
  id        String          @id @default(cuid())
  name      String
  type      String
  quantity  Int             @default(0)
  status    FurnitureStatus @default(NOVO)
  location  String
  patrimony String?         
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  
  // O móvel agora se vincula diretamente ao item do pedido
  requestItems RequestItem[] 
  movements    Movement[]

  @@map("furniture")
}

// ----------------------------------------------------------------------
// O "ENVELOPE" (CABEÇALHO DO PEDIDO)
// ----------------------------------------------------------------------
model Request {
  id              String        @id @default(cuid())
  userId          String
  sector          String        // Setor destino de todo o pedido
  status          RequestStatus @default(PENDENTE)
  notes           String?       
  rejectionReason String?       // <-- COLUNA NOVA ADICIONADA AQUI!
  reviewedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id])
  items           RequestItem[] // Relação 1 para N: Um pedido tem VÁRIOS itens

  @@map("requests")
}

// ----------------------------------------------------------------------
// OS "ITENS DO CARRINHO" 
// ----------------------------------------------------------------------
model RequestItem {
  id          String        @id @default(cuid())
  requestId   String        // ID do envelope pai
  type        String        // O tipo de item solicitado (ex: "Maca", "Cadeira")
  quantity    Int           @default(1)
  reason      String        // Motivo específico para este item
  status      RequestStatus @default(PENDENTE) 
  
  // Fica nulo até você vincular um patrimônio na entrega (opcional)
  furnitureId String?   

  request     Request    @relation(fields: [requestId], references: [id], onDelete: Cascade)
  furniture   Furniture? @relation(fields: [furnitureId], references: [id])

  @@map("request_items")
}

model Movement {
  id          String       @id @default(cuid())
  furnitureId String
  type        MovementType
  quantity    Int
  description String
  date        DateTime     @default(now())
  createdAt   DateTime     @default(now())

  furniture Furniture @relation(fields: [furnitureId], references: [id])

  @@map("movements")
}

// ----------------------------------------------------------------------
// MÓDULO DE ENXOVAL (TRAVESSEIROS)
// ----------------------------------------------------------------------

// Guarda o saldo atual (Vasos Comunicantes)
model PillowInventory {
  id              String   @id @default(cuid())
  stockLung       Int      @default(0)   // Quantidade no Pulmão (Estoque Hotelaria)
  stockCirculating Int      @default(0)   // Quantidade Rodando no Hospital
  updatedAt       DateTime @updatedAt    // Última vez que alguém mexeu no saldo

  @@map("pillow_inventory")
}

// Histórico de saídas da rouparia para o hospital
model PillowMovement {
  id          String   @id @default(cuid())
  quantity    Int      // Quantidade despachada
  destination String   // Setor destino (Ex: UTI, Quarto 302)
  requester   String   // Quem buscou/solicitou
  date        DateTime @default(now()) // Data e hora da saída

  @@map("pillow_movements")
}